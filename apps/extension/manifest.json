{
  "manifest_version": 3,
  "name": "AIDND DM Extension",
  "version": "1.1.0",
  "description": "AI Dungeon Master for AIDND — runs locally via Ollama",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://www.dnd5eapi.co/*"
  ],
  "optional_host_permissions": [
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://aidnd-web.safats61.workers.dev/*"
      ],
      "js": ["dist/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
