{
  "manifest_version": 3,
  "name": "AIDND DM Extension",
  "version": "1.0.0",
  "description": "AI Dungeon Master for AIDND — makes AI calls using your own API key or Claude Code subscription",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.x.ai/*",
    "https://api.mistral.ai/*",
    "https://openrouter.ai/*",
    "https://www.dnd5eapi.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://aidnd-web.safats61.workers.dev/*"
      ],
      "js": ["dist/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
