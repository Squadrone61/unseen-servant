{
  "name": "unseen-servant",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:all": "turbo dev --filter=@unseen-servant/web --filter=@unseen-servant/worker",
    "build:web": "cd apps/web && npx @opennextjs/cloudflare build",
    "deploy": "turbo deploy",
    "deploy:web": "cd apps/web && npx @opennextjs/cloudflare deploy",
    "deploy:worker": "cd apps/worker && wrangler deploy --env production",
    "test": "node scripts/test.mjs",
    "build:dm": "cd apps/dm-launcher && node build.mjs",
    "dead-code": "knip"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "knip": "^5.85.0",
    "tsx": "^4.19.4",
    "turbo": "^2",
    "typescript": "^5.9",
    "wrangler": "^4"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
