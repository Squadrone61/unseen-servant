{
  "name": "unseen-servant",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:all": "turbo dev --filter=@unseen-servant/web --filter=@unseen-servant/worker",
    "dev:dm": "cd apps/dm-launcher && node build.mjs --dev",
    "build:web": "cd apps/web && npx @opennextjs/cloudflare build",
    "build:dm": "cd apps/dm-launcher && node build.mjs",
    "deploy": "turbo deploy",
    "deploy:web": "cd apps/web && npx @opennextjs/cloudflare deploy",
    "deploy:worker": "cd apps/worker && wrangler deploy --env production",
    "test": "node scripts/test.mjs",
    "dead-code": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript": "^5.9",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
