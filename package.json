{
  "name": "ai-dungeon-master",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:web": "turbo dev --filter=@aidnd/web",
    "dev:worker": "turbo dev --filter=@aidnd/worker",
    "dev:all": "turbo dev --filter=@aidnd/web --filter=@aidnd/worker",
    "deploy": "turbo deploy",
    "deploy:worker": "turbo deploy --filter=@aidnd/worker",
    "deploy:web": "turbo deploy --filter=@aidnd/web",
    "test": "node scripts/test.mjs",
    "test:ui": "playwright test --ui",
    "dev:mcp": "tsx apps/mcp-bridge/src/index.ts",
    "build:dm": "cd apps/dm-launcher && node build.mjs",
    "dev:dm": "cd apps/dm-launcher && node build.mjs --dev && node dist/aidnd-dm-dev.mjs",
    "dead-code": "knip"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "knip": "^5.85.0",
    "turbo": "^2",
    "typescript": "^5.9"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
